# ==============================================================================
# Shared Environment Configuration - Pharmacy Management System (Example)
# ==============================================================================

# Application Meta
APP_NAME="Pharmacy Management System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Settings
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pharmacy_system
DB_USERNAME=root
DB_PASSWORD=

# Logging & Cache defaults for Laravel
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
BCRYPT_ROUNDS=12
CACHE_STORE=database
DATABASE_TRUNCATE_ON_MIGRATE=false
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# API Authentication & CORS Settings
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# Frontend (React) Config
VITE_API_BASE_URL=http://localhost:8000/api
